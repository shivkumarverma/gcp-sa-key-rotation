# ---------------------------------------------------------------------------
# Bootstrap env vars — the only env vars needed.
# Everything else is in GCP Secret Manager.
# ---------------------------------------------------------------------------

# GCP project that owns the Secret Manager secrets.
SECRET_MANAGER_PROJECT_ID=finops-billing-central-prod

# Secret ID whose value is the full service account JSON key string.
# This SA is used for IAM API, GCS, and all subsequent Secret Manager calls.
SERVICE_ACCOUNT_SECRET_ID=SERVICE_ACCOUNT_SECRET_ID

# Secret version to fetch (default: latest).
SECRET_MANAGER_VERSION=latest

# Log verbosity — kept as env var, not sensitive.
LOG_LEVEL=INFO


# Azure Communication Services — Email
ACS_CONNECTION_STRING=endpoint=https://devops-test.unitedstates.communication.azure.com/;accesskey=s1nRcSRA3rtJq238uQLBe1RuO5ul+1trj9y7mLfbt1nBK9hCZciee0J530cbllBrzlBISP+HIDXVzjUju4JhhQ==
ACS_SENDER_ADDRESS=DoNotReply@26cb33a6-5b6a-4764-9d64-d05caf6b3b7e.azurecomm.net

# Gmail SMTP fallback (used when ACS returns TooManyRequests)
